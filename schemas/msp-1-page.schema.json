{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/MSP-1-Protocol/msp-1-schemas/main/schemas/msp-1-page.schema.json",
  "title": "MSP-1 Page Declaration Schema",
  "description": "JSON Schema for an MSP-1 page-level declaration.",
  "type": "object",

  "required": ["@context", "protocol", "page"],

  "properties": {
    "@context": {
      "type": "string"
    },

    "protocol": {
      "type": "object",
      "required": ["name", "version"],
      "properties": {
        "name": {
          "type": "string",
          "const": "MSP-1"
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        }
      },
      "additionalProperties": false
    },

    "discovery": {
      "type": "object",
      "properties": {
        "wellKnown": {
          "type": "string",
          "const": "/.well-known/msp.json"
        },
        "canonical": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },

    "page": {
      "type": "object",
      "required": ["id", "url", "title"],
      "properties": {
        "id": {
          "type": "string",
          "format": "uri"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "canonical": {
          "type": "string",
          "format": "uri"
        },
        "title": {
          "type": "string"
        },
        "name": {
          "type": ["string", "object"]
        },
        "description": {
          "oneOf": [
            { "type": "string" },
            {
              "type": "object",
              "required": ["short"],
              "properties": {
                "short": { "type": "string" },
                "long": { "type": "string" },
                "alt": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "language": { "type": "string" },
                "lastUpdated": {
                  "type": "string",
                  "format": "date"
                }
              },
              "additionalProperties": false
            }
          ]
        },
        "intent": {
          "type": "object",
          "required": ["statement"],
          "properties": {
            "statement": { "type": "string" },
            "category": {
              "type": "string",
              "enum": [
                "informational",
                "transactional",
                "navigational",
                "instructional",
                "persuasive",
                "creative",
                "analytical",
                "warning",
                "meta"
              ]
            },
            "audience": { "type": "string" },
            "scope": { "type": "string" },
            "motivation": { "type": "string" },
            "interpretiveFrame": { "type": "string" },
            "priority": {
              "type": "string",
              "enum": ["low", "medium", "high", "critical"]
            },
            "lastUpdated": {
              "type": "string",
              "format": "date"
            }
          },
          "additionalProperties": false
        },
        "interpretiveFrame": {
          "type": "object",
          "required": ["frame"],
          "properties": {
            "frame": { "type": "string" },
            "category": {
              "type": "string",
              "enum": [
                "informational",
                "analytical",
                "creative",
                "speculative",
                "instructional",
                "opinion",
                "contextual-disclaimer",
                "safety",
                "meta",
                "other"
              ]
            },
            "tone": { "type": "string" },
            "perspective": { "type": "string" },
            "scope": { "type": "string" },
            "appliesToIntent": { "type": "boolean" },
            "notes": { "type": "string" },
            "lastUpdated": {
              "type": "string",
              "format": "date"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },

    "author": {
      "type": "object",
      "required": ["name", "type"],
      "properties": {
        "name": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["Person", "Organization"]
        },
        "id": {
          "type": "string",
          "format": "uri"
        },
        "role": { "type": "string" },
        "email": {
          "type": "string",
          "format": "email"
        }
      },
      "additionalProperties": false
    },

    "authority": {
      "type": "object",
      "properties": {
        "subjectId": {
          "type": "string",
          "format": "uri"
        },
        "scope": { "type": "string" },
        "level": { "type": "string" },
        "evidence": { "type": "string" },
        "jurisdiction": { "type": "string" },
        "effectiveDate": {
          "type": "string",
          "format": "date"
        }
      },
      "additionalProperties": false
    },

    "provenance": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "original",
            "derived",
            "aggregated",
            "ai-assisted",
            "ai-generated"
          ]
        },
        "source": { "type": "string" },
        "contributors": {
          "type": "array",
          "items": { "type": "string" }
        },
        "notes": { "type": "string" },
        "confidence": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },

    "canonical": {
      "type": "object",
      "required": ["url"],
      "properties": {
        "url": {
          "type": "string",
          "format": "uri"
        },
        "reason": { "type": "string" },
        "lastReviewed": {
          "type": "string",
          "format": "date"
        },
        "authority": {
          "type": "string",
          "format": "uri"
        }
      },
      "additionalProperties": false
    },

    "revision": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": { "type": "string" },
        "revisionDate": {
          "type": "string",
          "format": "date"
        },
        "revisionNotes": { "type": "string" },
        "revisionVersion": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        }
      },
      "additionalProperties": false
    },

    "trust": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "properties": {
            "level": {
              "type": "string",
              "enum": ["self-asserted", "verified", "authoritative"]
            },
            "scope": { "type": "string" },
            "provenance": { "type": "string" },
            "reviewer": { "type": "string" },
            "confidence": {
              "type": "string",
              "enum": ["low", "medium", "high"]
            }
          },
          "additionalProperties": false
        }
      ]
    }
  },

  "additionalProperties": false
}
